package Day_1.Anushka;
import java.util.*;
public class missingElementInRangeAnotherSolution {
    public static void main(String[] args) {
        int[]arr = { 1, 3, 5, 7};
        int low = 1;
        int high = 10;
        ArrayList<Integer> result = missingRange(arr , low , high);
        System.out.println(result);

    }
   public static ArrayList<Integer> missingRange(int[] arr , int low , int high){
        int[]set = new int[high - low + 1];
        ArrayList<Integer> ans = new ArrayList<>();
        for(int ele : arr){
            if(ele >= low && ele <= high) {
                set[ele - low] = 1;
            }
        }
        for(int i = low ; i <= high ; i++){
            if(set[i - low] == 0) {
                ans.add(i);
        }
    }
        return ans;

    }
}
